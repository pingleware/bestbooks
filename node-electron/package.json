{
  "name": "bestbooks",
  "version": "1.0.0-alpha",
  "description": "BestBooks Accounting Application Framework GUI",
  "main": "index.js",
  "build": {
    "appId": "work.pingleware.bestbooks",
    "productName": "bestbooks",
    "copyright": "Copyright © 2022 ${author}",
    "win": {
      "icon": "./assets/bestbooks.ico"
    },
    "linux": {
      "target": "deb",
      "icon": "./assets/bestbooks.png",
      "category": "Financial",
      "synopsis": "BestBooks Accounting Application Framework"
    },
    "mac": {
      "icon": "./assets/bestbooks.icns",
      "category": "public.app-category.financial"
    },
    "dmg": {
      "title": "${productName}_${version}",
      "icon": "./assets/bestbooks.icns",
      "contents": [
        {
          "x": 110,
          "y": 150
        },
        {
          "x": 240,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [],
    "extraFiles": []
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "debug": "electron . -menu=on",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "PRESSPAGE ENTERTAINMENT INC dba PINGLEWARE <maintainers@pingleware.work>",
  "license": "CC-BY-4.0",
  "devDependencies": {
    "electron": "^22.0.2",
    "electron-builder": "^22.10.3"
  },
  "dependencies": {
    "@pingleware/bestbooks-api": "file:../../bestbooks-api",
    "@pingleware/bestbooks-core": "file:../../bestbooks-core",
    "@pingleware/bestbooks-export": "file:../../bestbooks-export",
    "@pingleware/bestbooks-helpers": "file:../../bestbooks-helpers",
    "@pingleware/bestbooks-import": "file:../../bestbooks-import",
    "@pingleware/bestbooks-reports": "file:../../bestbooks-reports",
    "path": "^0.12.7",
    "yargs": "github:yargs/yargs"
  }
}
